{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string", "format": "uri" },
        "bio": { "type": "string" },
        "streak": { "type": "integer" },
        "aiTasksCount": { "type": "integer" },
        "darkMode": { "type": "boolean" },
        "notifications": { "type": "boolean" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["uid", "email"]
    },
    "Lecture": {
      "title": "Lecture",
      "description": "Uploaded lecture materials",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "duration": { "type": "string" },
        "thumbnail": { "type": "string", "format": "uri" },
        "summary": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title"]
    },
    "Task": {
      "title": "Task",
      "description": "Daily study tasks",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "time": { "type": "string" },
        "completed": { "type": "boolean" },
        "date": { "type": "string", "format": "date" }
      },
      "required": ["userId", "title", "date"]
    },
    "Flashcard": {
      "title": "Flashcard",
      "description": "Study flashcards",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "topic": { "type": "string" },
        "question": { "type": "string" },
        "answer": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "question", "answer"]
    },
    "Quiz": {
      "title": "Quiz",
      "description": "AI generated quizzes",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "topic": { "type": "string" },
        "score": { "type": "integer" },
        "totalQuestions": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "topic", "score"]
    },
    "MarketplaceItem": {
      "title": "MarketplaceItem",
      "description": "Study materials for sale",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "authorId": { "type": "string" },
        "price": { "type": "number" },
        "rating": { "type": "number" },
        "downloads": { "type": "integer" },
        "category": { "type": "string" },
        "thumbnail": { "type": "string", "format": "uri" }
      },
      "required": ["title", "authorId", "price"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/lectures/{lectureId}": {
      "schema": "Lecture",
      "description": "Lecture library"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "User tasks"
    },
    "/flashcards/{cardId}": {
      "schema": "Flashcard",
      "description": "User flashcards"
    },
    "/quizzes/{quizId}": {
      "schema": "Quiz",
      "description": "User quiz results"
    },
    "/marketplace/{itemId}": {
      "schema": "MarketplaceItem",
      "description": "Marketplace listings"
    }
  }
}
